{
  "projects": {
    "my-app": {
      "display_name": "My App",
      "path": "/Users/YOU/Developer/my-app",
      "xcodeproj": "MyApp.xcodeproj",
      "scheme": "MyApp",
      "configuration": "Release",
      "bundle_id": "com.example.myapp",
      "auto_increment_build": true,
      "git": {
        "default_mode": "auto",
        "remote": "origin",
        "worktree_base": "/Users/YOU/.ota-worktrees/my-app",
        "secrets_sync": [
          "Config/Secrets.xcconfig"
        ]
      }
    }
  }
}
