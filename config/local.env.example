# Copy to config/local.env and customize (local.env is gitignored).
# Run: ./scripts/setup.sh

# Required
OTA_BASE_URL=https://ota.yourdomain.com
OTA_ACCESS_TOKEN=
APPLE_TEAM_ID=XXXXXXXXXX

# Cloudflare Tunnel
OTA_HOSTNAME=ota.yourdomain.com
CLOUDFLARE_TUNNEL_NAME=ios-ota
CLOUDFLARE_TUNNEL_ID=your-tunnel-uuid-here

# Optional
OTA_PORT=8765
# XCODE_PATH=/Applications/Xcode.app/Contents/Developer
OTA_KEEP_BUILDS=5
OTA_MAX_AGE_DAYS=7
LAUNCHD_LABEL_PREFIX=com.local.ios-ota-builder
