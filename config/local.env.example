# Copy to config/local.env and customize (local.env is gitignored).
# Run: ./scripts/setup.sh

# Required
OTA_BASE_URL=https://ota.yourdomain.com
OTA_ACCESS_TOKEN=
APPLE_TEAM_ID=XXXXXXXXXX

# Cloudflare Tunnel
OTA_HOSTNAME=ota.yourdomain.com
CLOUDFLARE_TUNNEL_NAME=ios-ota
CLOUDFLARE_TUNNEL_ID=your-tunnel-uuid-here

# Optional
OTA_PORT=8765
# XCODE_PATH=/Applications/Xcode.app/Contents/Developer
OTA_KEEP_BUILDS=5
OTA_MAX_AGE_DAYS=7
LAUNCHD_LABEL_PREFIX=com.local.ios-ota-builder

# Admin login (optional — if OTA_ADMIN_PASSWORD_HASH is unset, token-only auth as today)
OTA_ADMIN_USERNAME=admin
# Set via ./scripts/set_admin_password.sh (stored single-quoted because the hash contains $)
OTA_ADMIN_PASSWORD_HASH=

# Token rotation (0 = disabled; requires admin login for remote recovery after rotation)
OTA_TOKEN_ROTATE_DAYS=30
OTA_TOKEN_CREATED_AT=

# OTA_SESSION_MAX_AGE=604800
# OTA_MAX_ACTIVE_SESSIONS=32

# F13 — Dirty git warning (default: warn only)
# OTA_FAIL_ON_DIRTY=1    # exit EC_ENVIRONMENT (10) if project repo has uncommitted changes

# F19 — Dashboard server status panel (also used by ota-status)
# OTA_STATUS_MIN_DISK_MB=5000
# OTA_STATUS_PROBE_TUNNEL=0    # set 1 to probe OTA_BASE_URL/health on each dashboard load

# F14 — Per-project build lock (prevents concurrent builds for the same project-id)
# OTA_BUILD_LOCK=fail             # fail (default) | wait
# OTA_BUILD_LOCK_TIMEOUT=30       # seconds when OTA_BUILD_LOCK=wait

# F15 — Build completion notifications
# OTA_NOTIFY=0                    # disable macOS notifications (default: on)
# OTA_WEBHOOK_URL=https://hooks.slack.com/services/...
# OTA_WEBHOOK_SECRET=             # optional; sent as X-OTA-Webhook-Secret header
